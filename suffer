local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local teleportOffset = CFrame.new(0, 0, -8)
local delay = 0.2
local key = Enum.KeyCode.R

local bulletTPEnabled = false
local targetPlayer = nil
local lockedTarget = nil
local isSpectating = false
local lockedTargetUserId = nil

local currentBringPlayer = nil
local detachedParts = {}

local circleLines = {}
local circleData = {[11] = 0}
local oldRadius = 0
local rendering = false

local CIRCLE_COLOR = Color3.fromRGB(255, 184, 243)
local CIRCLE_GRADIENT = Color3.fromRGB(255, 255, 255)

local espLabels = {}

--// CREATE 3D CIRCLE LINES
for i = 1, 32 do
    local l = Drawing.new("Line")
    l.Thickness = 2
    l.Visible = false
    circleLines[i] = l
end

local function tweenRadius(target)
    circleData[11] = circleData[11] + (target - circleData[11]) * 0.25
end

local function getClosestPlayer()
    local closest, dist = nil, math.huge
    local mouse = LocalPlayer:GetMouse()
    
    for _, v in ipairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local pos, onScreen = Camera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
            if onScreen then
                local mag = (Vector2.new(pos.X, pos.Y) - Vector2.new(mouse.X, mouse.Y)).Magnitude
                if mag < dist then
                    dist = mag
                    closest = v
                end
            end
        end
    end
    return closest
end

local function getPlayerByUserId(userId)
    for _, player in ipairs(Players:GetPlayers()) do
        if player.UserId == userId then
            return player
        end
    end
    return nil
end

local function handleTracer(obj)
    if not bulletTPEnabled then return end
    local n = obj.Name:lower()
    if n:find("tracer") or n:find("bullet") or n:find("beam") or obj:IsA("Trail") or obj:IsA("Beam") then
        task.spawn(function()
            while bulletTPEnabled and obj and obj.Parent do
                if obj:IsA("BasePart") then 
                    obj.Transparency = 1
                    obj.LocalTransparencyModifier = 1
                elseif obj:IsA("Trail") or obj:IsA("Beam") then 
                    obj.Enabled = false 
                end
                task.wait()
            end
        end)
    end
end

workspace.DescendantAdded:Connect(handleTracer)

task.spawn(function()
    for _, obj in ipairs(workspace:GetDescendants()) do
        handleTracer(obj)
    end
end)

--// DETACH LEFT HAND
local function detachLeftHand(player)
    local character = player.Character
    if not character then return end
    
    local leftHand = character:FindFirstChild("LeftHand") or 
                     character:FindFirstChild("Left Arm") or
                     character:FindFirstChild("LeftArm")
    
    if not leftHand then return end
    if detachedParts[player] then return end
    
    local originalParent = leftHand.Parent
    local originalCFrame = leftHand.CFrame
    
    local torso = character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso")
    local relativeCFrame = nil
    if torso then
        relativeCFrame = torso.CFrame:ToObjectSpace(originalCFrame)
    end
    
    local weldsToRemove = {}
    for _, weld in ipairs(character:GetDescendants()) do
        if weld:IsA("Weld") or weld:IsA("Motor6D") then
            if weld.Part0 == leftHand or weld.Part1 == leftHand then
                table.insert(weldsToRemove, weld)
            end
        end
    end
    
    for _, weld in ipairs(weldsToRemove) do
        weld:Destroy()
    end
    
    leftHand.LocalTransparencyModifier = 1
    leftHand.Transparency = 1
    
    leftHand.Parent = workspace
    leftHand.CFrame = originalCFrame
    
    detachedParts[player] = {
        Part = leftHand,
        OriginalParent = originalParent,
        OriginalCFrame = originalCFrame,
        RelativeCFrame = relativeCFrame,
        Torso = torso
    }
end

local function reattachLeftHand(player)
    if not detachedParts[player] then return end
    
    local data = detachedParts[player]
    local part = data.Part
    local originalParent = data.OriginalParent
    local originalCFrame = data.OriginalCFrame
    local relativeCFrame = data.RelativeCFrame
    local torso = data.Torso or originalParent:FindFirstChild("UpperTorso") or originalParent:FindFirstChild("Torso")
    
    if part and originalParent then
        if torso and relativeCFrame then
            part.CFrame = torso.CFrame * relativeCFrame
        elseif originalCFrame then
            part.CFrame = originalCFrame
        end
        
        part.LocalTransparencyModifier = 0
        part.Transparency = 0
        
        part.Parent = originalParent
        
        local leftShoulder = originalParent:FindFirstChild("LeftShoulder") or 
                             originalParent:FindFirstChild("Left Arm") or
                             originalParent:FindFirstChild("LeftArm")
        
        if leftShoulder and leftShoulder:IsA("Motor6D") then
            leftShoulder.Part0 = torso or originalParent:FindFirstChild("UpperTorso") or originalParent:FindFirstChild("Torso")
            leftShoulder.Part1 = part
        else
            local newWeld = Instance.new("Weld")
            local torsoPart = torso or originalParent:FindFirstChild("UpperTorso") or originalParent:FindFirstChild("Torso")
            newWeld.Part0 = torsoPart
            newWeld.Part1 = part
            if torsoPart then
                newWeld.C0 = torsoPart.CFrame:Inverse() * part.CFrame
                newWeld.Parent = part
            end
        end
    end
    
    detachedParts[player] = nil
end

local function pressReload()
    VirtualInputManager:SendKeyEvent(true, key, false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, key, false, game)
end

local function getTool()
    local char = LocalPlayer.Character
    if not char then return nil end
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("Tool") then
            return v
        end
    end
    return nil
end

task.spawn(function()
    while true do
        local t = getTool()
        if t then
            local ammo = t:FindFirstChild("Ammo", true)
            if ammo and ammo:IsA("ValueBase") then
                if ammo.Value <= 0 then
                    local r = t:FindFirstChild("Reload", true) or t:FindFirstChild("ReloadFunction", true)
                    if r then
                        pcall(function()
                            r:FireServer()
                        end)
                    else
                        pressReload()
                    end
                    task.wait(0.8)
                end
            end
        end
        task.wait(delay)
    end
end)

local function stopSpectate()
    isSpectating = false
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        Camera.CameraSubject = LocalPlayer.Character.Humanoid
    end
end

local particleAura = game:GetObjects("rbxassetid://134645216613107")[1]
local activeParticles = {}
local auraTarget = nil

local function applyColor(obj)
    local colorSeq = ColorSequence.new(CIRCLE_COLOR)

    for _, v in ipairs(obj:GetDescendants()) do
        if v:IsA("ParticleEmitter") or v:IsA("Beam") or v:IsA("Trail") then
            v.Color = colorSeq
        elseif v:IsA("PointLight") then
            v.Color = CIRCLE_COLOR
        end
    end
end

local function clearAura()
    for _, v in ipairs(activeParticles) do
        if v then
            v:Destroy()
        end
    end
    activeParticles = {}
    auraTarget = nil
end

local function applyAura(character)
    if not character then return end
    
    if lockedTarget and lockedTarget.Character ~= character then
        return
    end
    
    clearAura()
    auraTarget = character

    local clone = particleAura:Clone()
    applyColor(clone)

    for _, part in ipairs(clone:GetChildren()) do
        local target = character:FindFirstChild(part.Name)

        if target then
            for _, obj in ipairs(part:GetChildren()) do
                obj.Name = "\0"
                obj.Parent = target
                table.insert(activeParticles, obj)
            end
        end
    end

    clone:Destroy()
end

local function lockTarget(player)
    if not player then return end
    
    lockedTarget = player
    targetPlayer = player
    bulletTPEnabled = true
    lockedTargetUserId = player.UserId
    
    if not currentBringPlayer or currentBringPlayer ~= player then
        if currentBringPlayer then
            reattachLeftHand(currentBringPlayer)
        end
        detachLeftHand(player)
        currentBringPlayer = player
    end
    
    if player.Character then
        applyAura(player.Character)
    end
end

local function unlockTarget()
    lockedTarget = nil
    targetPlayer = nil
    bulletTPEnabled = false
    lockedTargetUserId = nil
    stopSpectate()
    
    if currentBringPlayer then
        reattachLeftHand(currentBringPlayer)
        currentBringPlayer = nil
    end
    
    for i = 1, 32 do
        circleLines[i].Visible = false
    end
    rendering = false
    
    clearAura()
end

local function addESP(player)
    if player == LocalPlayer then return end
    
    if espLabels[player.UserId] then
        espLabels[player.UserId]:Remove()
        espLabels[player.UserId] = nil
    end
    
    local label = Drawing.new("Text")
    label.Size = 14
    label.Center = true
    label.Outline = true
    label.OutlineColor = Color3.fromRGB(0, 0, 0)
    label.Color = Color3.fromRGB(255, 255, 255)
    label.Font = Drawing.Fonts.Plex
    label.Visible = false
    label.ZIndex = 1000
    
    espLabels[player.UserId] = label
end

local function removeESP(player)
    local label = espLabels[player.UserId]
    if label then
        label:Remove()
        espLabels[player.UserId] = nil
    end
end

local function refreshESP()
    for userId, label in pairs(espLabels) do
        local player = Players:GetPlayerByUserId(userId)
        if not player or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
            label.Visible = false
            continue
        end
        
        local hrp = player.Character.HumanoidRootPart
        local head = player.Character:FindFirstChild("Head")
        
        if not hrp or not head then
            label.Visible = false
            continue
        end
        
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then
            label.Visible = false
            continue
        end
        
        local worldPos = head.Position + Vector3.new(0, 2.5, 0)
        local screenPos, onScreen = Camera:WorldToViewportPoint(worldPos)
        
        if onScreen and screenPos.Z > 0 then
            label.Position = Vector2.new(screenPos.X, screenPos.Y)
            label.Text = player.DisplayName or player.Name
            
            if lockedTarget and lockedTarget.UserId == userId then
                label.Color = Color3.fromRGB(255, 184, 243)
            else
                label.Color = Color3.fromRGB(255, 255, 255)
            end
            
            label.Visible = true
        else
            label.Visible = false
        end
    end
end

local mouse = LocalPlayer:GetMouse()
local mt = getrawmetatable(game)
local oldIndex = mt.__index
local oldNamecall = mt.__namecall

setreadonly(mt, false)

mt.__index = function(self, key)
    if not checkcaller() and self == mouse then
        if key == "Hit" and bulletTPEnabled then
            local target = targetPlayer
            if target then
                local handData = detachedParts[target]
                local partToAim = nil
                
                if handData and handData.Part and handData.Part.Parent then
                    partToAim = handData.Part
                elseif target.Character then
                    partToAim = target.Character:FindFirstChild("Head") or 
                               target.Character:FindFirstChild("UpperTorso") or
                               target.Character:FindFirstChild("HumanoidRootPart")
                end
                
                if partToAim and partToAim.Parent then
                    local targetPos = partToAim.Position
                    -- Add slight randomization to avoid detection
                    local randomOffset = Vector3.new(
                        (math.random() - 0.5) * 0.01,
                        (math.random() - 0.5) * 0.01,
                        (math.random() - 0.5) * 0.01
                    )
                    return CFrame.new(targetPos + randomOffset)
                end
            end
        end
    end
    return oldIndex(self, key)
end

mt.__namecall = function(self, ...)
    local args = {...}
    local method = getnamecallmethod()
    
    if not checkcaller() and self == mouse then
        if method == "Target" and bulletTPEnabled then
            local target = targetPlayer
            if target and target.Character then
                local head = target.Character:FindFirstChild("Head")
                if head then
                    return head
                end
            end
        end
    end
    
    return oldNamecall(self, ...)
end

setreadonly(mt, true)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.C then
        if lockedTarget then
            unlockTarget()
        else
            local t = getClosestPlayer()
            if t then
                lockTarget(t)
            end
        end
    end
    
    if input.KeyCode == Enum.KeyCode.Z then
        if lockedTarget then
            isSpectating = not isSpectating
            if isSpectating then
                if lockedTarget.Character and lockedTarget.Character:FindFirstChild("Humanoid") then
                    Camera.CameraSubject = lockedTarget.Character.Humanoid
                end
            else
                stopSpectate()
            end
        end
    end
end)

local function onCharacterAdded(player)
    if lockedTargetUserId and player.UserId == lockedTargetUserId then
        task.wait(0.3)
        
        if player.Character then
            lockedTarget = player
            targetPlayer = player
            bulletTPEnabled = true
            
            if currentBringPlayer then
                reattachLeftHand(currentBringPlayer)
            end
            detachLeftHand(player)
            currentBringPlayer = player
            
            applyAura(player.Character)
        end
    end
    
    if currentBringPlayer == player then
        task.wait(0.1)
        detachLeftHand(player)
    end
    
    if lockedTarget == player and player.Character then
        task.wait(0.2)
        applyAura(player.Character)
    end
    
    if player ~= LocalPlayer then
        addESP(player)
    end
end

for _, player in ipairs(Players:GetPlayers()) do
    if player ~= LocalPlayer then
        addESP(player)
        
        player.CharacterAdded:Connect(function()
            onCharacterAdded(player)
        end)
    end
end

Players.PlayerAdded:Connect(function(player)
    if player ~= LocalPlayer then
        addESP(player)
    end
    
    player.CharacterAdded:Connect(function()
        onCharacterAdded(player)
    end)
end)

Players.PlayerRemoving:Connect(function(player)
    if currentBringPlayer == player then
        detachedParts[player] = nil
        currentBringPlayer = nil
    end
    if lockedTarget == player then
        unlockTarget()
    end
    removeESP(player)
end)

local function teleportBullet(tool)
    if not bulletTPEnabled or not tool then return end
    local target = targetPlayer
    if not target then return end
    
    local handData = detachedParts[target]
    local targetPart = handData and handData.Part
    
    if not targetPart or not targetPart.Parent then return end
    
    local origin = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if origin then
        local grip = tool.Grip
        tool.Parent = LocalPlayer.Backpack
        
        -- Calculate new grip
        local targetCFrame = targetPart.CFrame
        local originCFrame = origin.CFrame
        local newGrip = originCFrame:ToObjectSpace(targetCFrame):inverse()
        
        tool.Grip = newGrip
        tool.Parent = LocalPlayer.Character
        
        -- Small delay to ensure grip applies
        RunService.Heartbeat:Wait()
        
        -- Reset
        tool.Parent = LocalPlayer.Backpack
        tool.Grip = grip
        tool.Parent = LocalPlayer.Character
    end
end

local connections = {}

local function handleCharacter(char)
    if connections.char_child_added then
        connections.char_child_added:Disconnect()
        connections.char_child_added = nil
    end
    if connections.child_removing_char then
        connections.child_removing_char:Disconnect()
        connections.child_removing_char = nil
    end
    if connections.tool_activated then
        connections.tool_activated:Disconnect()
        connections.tool_activated = nil
    end
    
    connections.char_child_added = char.ChildAdded:Connect(function(tool)
        if tool:IsA("Tool") then
            -- Disable default grip connections
            for _, v in ipairs(getconnections(tool:GetPropertyChangedSignal("Grip"))) do
                v:Disable()
            end
            if connections.tool_activated then
                connections.tool_activated:Disconnect()
            end
            connections.tool_activated = tool.Activated:Connect(function()
                teleportBullet(tool)
            end)
        end
    end)
    
    connections.child_removing_char = char.ChildRemoved:Connect(function()
        if connections.tool_activated then
            connections.tool_activated:Disconnect()
            connections.tool_activated = nil
        end
    end)
end

local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
handleCharacter(char)

LocalPlayer.CharacterAdded:Connect(function(c)
    handleCharacter(c)
end)

LocalPlayer.CharacterRemoving:Connect(function()
    if connections.char_child_added then
        connections.char_child_added:Disconnect()
        connections.char_child_added = nil
    end
    if connections.child_removing_char then
        connections.child_removing_char:Disconnect()
        connections.child_removing_char = nil
    end
    if connections.tool_activated then
        connections.tool_activated:Disconnect()
        connections.tool_activated = nil
    end
end)

RunService.RenderStepped:Connect(function(dt)
    -- Bring the left hand
    if currentBringPlayer and not isSpectating then
        local myChar = LocalPlayer.Character
        if myChar and myChar:FindFirstChild("HumanoidRootPart") then
            local handData = detachedParts[currentBringPlayer]
            if handData and handData.Part then
                handData.Part.CFrame = myChar.HumanoidRootPart.CFrame * teleportOffset
                handData.Part.LocalTransparencyModifier = 1
                handData.Part.Transparency = 1
            else
                detachLeftHand(currentBringPlayer)
            end
        end
    end
    
    if isSpectating and lockedTarget then
        if lockedTarget.Character and lockedTarget.Character:FindFirstChild("Humanoid") then
            Camera.CameraSubject = lockedTarget.Character.Humanoid
        end
    end
    if lockedTarget and lockedTarget.Character and lockedTarget.Character:FindFirstChild("UpperTorso") then
        local char = lockedTarget.Character
        local torso = char.UpperTorso
        
        rendering = true
        local position = torso.Position
        
        local size = char:GetExtentsSize()
        local newRadius = math.clamp((size.X + size.Z) / 3, 2, 10)
        
        if math.abs(newRadius - oldRadius) > 1.1 then
            oldRadius = newRadius
            circleData[11] = newRadius + 3
        end
        
        tweenRadius(newRadius)
        local radius = circleData[11]
        local offset = (tick() * 4) % (math.pi * 2)
        
        for i = 1, 32 do
            local line = circleLines[i]
            
            local angle1 = (math.pi * 2 / 32) * (i - 1) + offset
            local angle2 = (math.pi * 2 / 32) * i + offset
            
            local world1 = position + Vector3.new(math.cos(angle1) * radius, 0, math.sin(angle1) * radius)
            local world2 = position + Vector3.new(math.cos(angle2) * radius, 0, math.sin(angle2) * radius)
            
            local p1, vis1 = Camera:WorldToViewportPoint(world1)
            local p2, vis2 = Camera:WorldToViewportPoint(world2)
            
            if vis1 and vis2 then
                local fade = i / 32
                
                line.From = Vector2.new(p1.X, p1.Y)
                line.To = Vector2.new(p2.X, p2.Y)
                line.Transparency = math.max(0, fade)
                line.Color = CIRCLE_COLOR:Lerp(CIRCLE_GRADIENT, i / 32)
                line.Visible = true
            else
                line.Visible = false
            end
        end
        
    elseif rendering then
        oldRadius = 0
        rendering = false
        for i = 1, 32 do
            circleLines[i].Visible = false
        end
    end
    refreshESP()
    
    -- Auto-re-lock if target respawned
    if lockedTargetUserId and not lockedTarget then
        local player = getPlayerByUserId(lockedTargetUserId)
        if player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            lockTarget(player)
        end
    end
    if lockedTarget then
        if not lockedTarget.Parent then
            lockedTarget = nil
            targetPlayer = nil
            bulletTPEnabled = false
            if currentBringPlayer then
                reattachLeftHand(currentBringPlayer)
                currentBringPlayer = nil
            end
            for i = 1, 32 do
                circleLines[i].Visible = false
            end
            rendering = false
            clearAura()
        elseif not lockedTarget.Character or not lockedTarget.Character:FindFirstChild("HumanoidRootPart") then
            targetPlayer = nil
            bulletTPEnabled = false
            if currentBringPlayer then
                reattachLeftHand(currentBringPlayer)
                currentBringPlayer = nil
            end
            for i = 1, 32 do
                circleLines[i].Visible = false
            end
            rendering = false
            clearAura()
        end
    end
end)
